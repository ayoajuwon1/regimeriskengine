# Copy this file to .env and add your OpenAI API key.
# Keep .env local only. It is gitignored.
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4.1-mini
# Optional when the API is hosted on a different origin or path.
# Accepted examples: http://localhost:3000, http://localhost:3000/api, /api
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
# Optional UI label override for the analysis provider/model.
# NEXT_PUBLIC_ANALYSIS_MODEL_LABEL=gpt-4.1-mini
